# Core broker settings
SECRET_BROKER_BIND=127.0.0.1:4815
SECRET_BROKER_DB=sqlite://secret-broker.db?mode=rwc
SECRET_BROKER_MODE=monitor

# Bootstrap API keys
SECRET_BROKER_CLIENT_API_KEY=
SECRET_BROKER_APPROVER_API_KEY=

# Policy
SECRET_BROKER_ALLOWED_TARGET_PREFIXES=
SECRET_BROKER_MAX_AMOUNT_CENTS=10000
SECRET_BROKER_CAPABILITY_TTL_SECONDS=300
SECRET_BROKER_REQUEST_TTL_SECONDS=86400
SECRET_BROKER_RATE_LIMIT_PER_MINUTE=60

# Bitwarden / provider integration
SECRET_BROKER_BITWARDEN_BASE_URL=http://127.0.0.1:8087
SECRET_BROKER_BITWARDEN_TOKEN=
SECRET_BROKER_BITWARDEN_TIMEOUT_SECONDS=30

# Trusted execution adapters
SECRET_BROKER_EXECUTION_ADAPTER_MODE=off
SECRET_BROKER_REQUEST_SIGN_ADAPTER_URL=

# Runtime identity
# Use a non-off baseline when host-specific required modes are configured.
SECRET_BROKER_IDENTITY_VERIFICATION_MODE=stub
SECRET_BROKER_IDENTITY_ATTESTATION_KEY=
SECRET_BROKER_IDENTITY_ATTESTATION_MAX_AGE_SECONDS=300
SECRET_BROKER_TRUSTED_RUNTIME_IDS=
SECRET_BROKER_TRUSTED_HOST_IDS=
# Example host-signed preview host config:
# SECRET_BROKER_IDENTITY_VERIFICATION_MODE=host-signed
# SECRET_BROKER_IDENTITY_HOST_SIGNING_KEYS=openclaw-http-host=<strong-random-key>
# SECRET_BROKER_TRUSTED_HOST_RUNTIME_PAIRS=openclaw-http-host=openclaw-runtime-v1

# Optional OpenClaw / host app integration notes
# OpenClaw should point at the broker HTTP API and use the client key only.
# Approvals should be handled by a separate human/approver channel.
